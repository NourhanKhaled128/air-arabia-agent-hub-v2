generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id           Int             @id @default(autoincrement())
  title        String
  slug         String          @unique
  category     String
  description  String
  overview     String
  coverImage   String?
  author       String
  status       String          @default("Draft")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  images       ArticleImage[]
  dispositions Disposition[]
  escalations  Escalation[]
  keywords     Keyword[]
  notes        Note[]
  procedures   ProcedureStep[]
  references   Reference[]
}

model ProcedureStep {
  id        Int     @id @default(autoincrement())
  articleId Int
  stepNo    Int
  title     String?
  content   String
  image     String?
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Disposition {
  id        Int     @id @default(autoincrement())
  articleId Int
  content   String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Escalation {
  id        Int     @id @default(autoincrement())
  articleId Int
  content   String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Note {
  id        Int     @id @default(autoincrement())
  articleId Int
  content   String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Reference {
  id        Int     @id @default(autoincrement())
  articleId Int
  title     String
  link      String?
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Keyword {
  id        Int     @id @default(autoincrement())
  articleId Int
  value     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model ArticleImage {
  id        Int     @id @default(autoincrement())
  articleId Int
  image     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}
