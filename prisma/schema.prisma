generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id           Int             @id @default(autoincrement())
  title        String
  slug         String          @unique
  categoryId   Int?
  category     Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  folderId     Int?
  folder       CategoryFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  description  String
  overview     String
  coverImage   String?
  author       String
  status       String          @default("Draft")
  viewCount    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  images       ArticleImage[]
  dispositions Disposition[]
  escalations  Escalation[]
  keywords     Keyword[]
  notes        Note[]
  procedures   ProcedureStep[]
  references   Reference[]
  scenarios    Scenario[]
  attachments  Attachment[]
  updates      ArticleUpdate[]
  comments     Comment[]
  feedback     Feedback[]
  chatTemplates  ChatTemplate[]
  emailTemplates EmailTemplate[]
  decisionTrees  DecisionTree[]
}

model ArticleUpdate {
  id        Int      @id @default(autoincrement())
  articleId Int
  title     String
  content   String
  userName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model ProcedureStep {
  id        Int     @id @default(autoincrement())
  articleId Int
  stepNo    Int
  title     String?
  content   String
  image     String?
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Disposition {
  id        Int      @id @default(autoincrement())
  articleId Int
  code      String?
  content   String
  images    String[] @default([])
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Escalation {
  id         Int      @id @default(autoincrement())
  articleId  Int
  department String?
  condition  String?
  content    String
  images     String[] @default([])
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Note {
  id        Int      @id @default(autoincrement())
  articleId Int
  type      String   @default("Information")
  content   String
  images    String[] @default([])
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Reference {
  id        Int      @id @default(autoincrement())
  articleId Int
  title     String
  type      String   @default("Internal SOP")
  link      String?
  images    String[] @default([])
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Keyword {
  id        Int     @id @default(autoincrement())
  articleId Int
  value     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model ArticleImage {
  id        Int     @id @default(autoincrement())
  articleId Int
  image     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Scenario {
  id        Int      @id @default(autoincrement())
  articleId Int
  situation String
  response  String
  images    String[] @default([])
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model ChatTemplate {
  id        Int     @id @default(autoincrement())
  articleId Int
  title     String
  content   String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        Int     @id @default(autoincrement())
  articleId Int
  title     String
  subject   String
  body      String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model DecisionTree {
  id              Int            @id @default(autoincrement())
  title           String
  slug            String         @unique
  description     String?
  topic           String?
  status          String         @default("Draft")
  author          String
  sourceArticleId Int?
  sourceArticle   Article?       @relation(fields: [sourceArticleId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  nodes           DecisionNode[]
}

model DecisionNode {
  id      Int              @id @default(autoincrement())
  treeId  Int
  tree    DecisionTree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  type    String
  text    String
  order   Int
  options DecisionOption[] @relation("SourceNode")
}

model DecisionOption {
  id           Int          @id @default(autoincrement())
  nodeId       Int
  node         DecisionNode @relation("SourceNode", fields: [nodeId], references: [id], onDelete: Cascade)
  label        String
  targetNodeId Int?
  order        Int          @default(0)
}

model Attachment {
  id        Int      @id @default(autoincrement())
  articleId Int
  fileName  String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Disruption {
  id          Int      @id @default(autoincrement())
  airportCode String
  message     String
  level       String   @default("Medium")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  slug        String           @unique
  description String?
  color       String?
  icon        String?
  visible     Boolean          @default(true)
  order       Int              @default(0)
  group       String           @default("Knowledge Base")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  articles    Article[]
  folders     CategoryFolder[]
}

model CategoryFolder {
  id         Int      @id @default(autoincrement())
  categoryId Int
  name       String
  order      Int      @default(0)
  visible    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  articles   Article[]
}

model SidebarLink {
  id        Int      @id @default(autoincrement())
  label     String
  href      String
  icon      String   @default("Link2")
  section   String   @default("tools")
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ImportantLink {
  id          Int      @id @default(autoincrement())
  title       String
  url         String
  description String?
  icon        String   @default("Link2")
  order       Int      @default(0)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HomeWidget {
  id        Int      @id @default(autoincrement())
  type      String
  order     Int      @default(0)
  size      String   @default("half")
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  priority    String    @default("Medium")
  status      String    @default("Draft")
  audience    String?
  publishDate DateTime?
  expiryDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TrainingCourse {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  duration     String?
  passingScore Int?
  status       String   @default("Draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lessons Lesson[]
}

model Lesson {
  id       Int    @id @default(autoincrement())
  courseId Int
  title    String
  content  String
  order    Int

  course TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model MediaFile {
  id         Int      @id @default(autoincrement())
  name       String
  url        String
  mimeType   String
  size       Int
  uploadedAt DateTime @default(now())
}

model Notification {
  id        Int       @id @default(autoincrement())
  title     String
  message   String
  audience  String?
  status    String    @default("Draft")
  sendDate  DateTime?
  sent      Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  userName  String
  createdAt DateTime @default(now())
}

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  color       String   @default("bg-slate-100 text-slate-700")
  permissions String[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  status       String   @default("Active")
  roleId       Int
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Airport {
  id        Int      @id @default(autoincrement())
  code      String
  city      String
  airport   String
  country   String
  terminal  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model DispositionCode {
  id          Int      @id @default(autoincrement())
  code        String
  label       String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model EscalationContact {
  id          Int      @id @default(autoincrement())
  issueType   String
  escalateTo  String
  contactInfo String
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Comment {
  id         Int      @id @default(autoincrement())
  articleId  Int
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorName String   @default("Agent")
  content    String
  status     String   @default("Pending")
  createdAt  DateTime @default(now())
}

model Feedback {
  id         Int      @id @default(autoincrement())
  articleId  Int
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorName String?
  helpful    Boolean
  message    String?
  status     String   @default("New")
  createdAt  DateTime @default(now())
}
